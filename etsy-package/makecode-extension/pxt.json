{
    "name": "mission-control-companion",
    "version": "0.1.0",
    "description": "Companion firmware blocks for the mission-control browser app — pairs any micro:bit V2 with the Etsy-distributed Mini Mission Control app (https://abourdim.github.io/mission-control/). Receives D-pad commands over BLE UART and displays them as LED arrows. Optional TTS-echo and two-way text.",
    "license": "MIT",
    "dependencies": {
        "core": "*",
        "microphone": "*",
        "bluetooth": "*",
        "radio": "*"
    },
    "files": [
        "main.ts",
        "mission-control.ts",
        "README.md"
    ],
    "testFiles": [],
    "public": true,
    "preferredEditor": "tsprj",
    "supportedTargets": [
        "microbit"
    ],
    "yotta": {
        "config": {
            "microbit-dal": {
                "bluetooth": {
                    "enabled": 1,
                    "open": 1,
                    "whitelist": 0,
                    "security_level": 0,
                    "uart": 1,
                    "event_service": 1,
                    "device_info_service": 1,
                    "advertising_interval": 200,
                    "advertising_power": 7
                }
            }
        }
    }
}
