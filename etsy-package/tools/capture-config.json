{
  "productName": "Mini Mission Control",
  "appContainer": ".app",
  "toastContainer": ".toast-container",

  "onboarding": {
    "localStorageKey": "mc_onboarded",
    "closeSelectors": [".ob-close", "[data-close-onboarding]", "button:has-text(\"Start\")"]
  },

  "theme": {
    "storageKey": "mc_theme",
    "default": "default",
    "attr": "data-theme",
    "attrTarget": "html"
  },

  "tabs": [
    { "slug": "live",    "selector": ".card:has(#videoStage)", "settle": 500, "scrollTo": ".card-title" },
    { "slug": "room",    "selector": "details:has(#roomInput)", "settle": 300, "scrollTo": "details:has(#roomInput)" },
    { "slug": "dpad",    "selector": ".card:has(.dpad-section)", "settle": 300, "scrollTo": ".card:has(.dpad-section)" },
    { "slug": "text",    "selector": ".card:has(#textInput)", "settle": 300, "scrollTo": ".card:has(#textInput)" },
    { "slug": "microbit","selector": "details:has(#mbStatus)", "settle": 300, "scrollTo": "details:has(#mbStatus)" },
    { "slug": "logs",    "selector": "details:has(#log)", "settle": 300, "scrollTo": "details:has(#log)" }
  ],

  "synthetic": {
    "connect": {
      "statusSelector": "#status",
      "statusClassOn": "status-connected",
      "pillOnText": { "en": "Connected", "fr": "Connecté", "ar": "متصل" },
      "pillOffText": { "en": "Idle", "fr": "Inactif", "ar": "خامل" }
    },
    "activityFeed": {
      "containerSelector": "#log",
      "entryClass": "log-entry",
      "entries": {
        "en": [
          "Room code: ASTRO · Paired with device 2",
          "Camera ready · 1280x720 · audio on",
          "RX: DPAD LEFT pressed",
          "RX: DPAD RIGHT released",
          "Bluetooth UART to micro:bit CMSIS-DAP connected"
        ],
        "fr": [
          "Code de salle : ASTRO · Appaire avec appareil 2",
          "Camera prete · 1280x720 · audio active",
          "RX : D-pad GAUCHE presse",
          "RX : D-pad DROITE relache",
          "UART Bluetooth vers micro:bit CMSIS-DAP connecte"
        ],
        "ar": [
          "رمز الغرفة: ASTRO · مرتبط مع الجهاز 2",
          "الكاميرا جاهزة · 1280x720 · الصوت مفعل",
          "RX: D-pad يسار تم الضغط",
          "RX: D-pad يمين تم الإفلات",
          "UART Bluetooth إلى micro:bit CMSIS-DAP متصل"
        ]
      }
    },
    "pills": []
  },

  "variants": {
    "themes": { "storageKey": "mc_theme", "values": [] },
    "models": { "selector": null, "values": [] }
  },

  "pairs": [],

  "annotations": [
    {
      "slug": "live",
      "tab": "live",
      "target": "#videoStage",
      "caption": {
        "en": "Peer-to-peer video · WebRTC",
        "fr": "Video pair-a-pair · WebRTC",
        "ar": "فيديو بين الأقران · WebRTC"
      }
    },
    {
      "slug": "dpad",
      "tab": "dpad",
      "target": ".dpad-section",
      "caption": {
        "en": "D-pad commands over the data channel",
        "fr": "Commandes D-pad via le canal de donnees",
        "ar": "أوامر D-pad عبر قناة البيانات"
      }
    }
  ],

  "heroTabs": ["live", "dpad", "microbit"]
}
